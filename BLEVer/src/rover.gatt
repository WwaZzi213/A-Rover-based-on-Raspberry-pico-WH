// Rover BLE GATT Database

// Generic Access
PRIMARY_SERVICE, GAP_SERVICE
CHARACTERISTIC, GAP_DEVICE_NAME, READ, "ROVER_BLE"

// Generic Attribute
PRIMARY_SERVICE, GATT_SERVICE

// Rover Control Service
// UUID: 12345678-1234-1234-1234-1234567890ab
PRIMARY_SERVICE, 12345678-1234-1234-1234-1234567890ab

// CMD: Write Without Response
// UUID: 12345678-1234-1234-1234-1234567890ac
CHARACTERISTIC, 12345678-1234-1234-1234-1234567890ac, DYNAMIC|WRITE_WITHOUT_RESPONSE, 00

// ACK: Notify
// UUID: 12345678-1234-1234-1234-1234567890ad
CHARACTERISTIC, 12345678-1234-1234-1234-1234567890ad, DYNAMIC|NOTIFY, 00
CLIENT_CHARACTERISTIC_CONFIGURATION
